# Copy this file to .env and fill in your values. .env is gitignored.

# Riot API key — get one at https://developer.riotgames.com
# NOTE: development keys expire every 24 h and must be refreshed there.
RIOT_API_KEY=RGAPI-your-key-here

# Accounts to track: comma-separated Riot IDs (any number of them).
ACCOUNTS=YourName#EUW, SmurfName#EUW

# Your platform/server (default: euw1). The matching regional routing for
# match history is derived automatically. Valid values:
#   euw1 eun1 tr1 ru          (Europe)
#   na1 br1 la1 la2           (Americas)
#   kr jp1                    (Asia)
#   oc1 ph2 sg2 th2 tw2 vn2   (SEA)
#PLATFORM=euw1

# Optional: override the sqlite database location (default: data/lol.sqlite)
#DB_PATH=/somewhere/else/lol.sqlite
